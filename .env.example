PORT=8080

# PostgreSQL connection string (e.g. Neon, Cloud SQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET="replace-with-random-secret"

# Master key for license generation — generate with: openssl rand -hex 32
MASTER_KEY="replace-with-random-hex-key"

# Admin email for master operations
MASTER_EMAIL=admin@example.com

# SMTP credentials for transactional email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
